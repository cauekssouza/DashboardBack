// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ATTENDANT)  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  
  
  tickets           Ticket[]      @relation("CreatedTickets")  
  assignedTickets   Ticket[]      @relation("AssignedTickets") 
  updatedTickets    Ticket[]      @relation("UpdatedTickets")  
  messages          TicketMessage[]
  attachments       Attachment[]
  refreshTokens     RefreshToken[]
  activities        Activity[]

  @@map("users")
}

model Ticket {
  id          String        @id @default(uuid())
  title       String
  description String?
  status      TicketStatus  @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  source      TicketSource  @default(EMAIL)
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id])
  
  assignedTo  String?
  assignedUser User?        @relation("AssignedTickets", fields: [assignedTo], references: [id])
  
  createdById String
  createdBy   User          @relation("CreatedTickets", fields: [createdById], references: [id])
  
  updatedById String?
  updatedBy   User?         @relation("UpdatedTickets", fields: [updatedById], references: [id])
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  closedAt    DateTime?
  slaDueAt    DateTime?
  
  messages    TicketMessage[]
  tags        Tag[]
  attachments Attachment[]
}

model Customer {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  phone        String?
  company      String?
  cpfCnpj      String?
  address      String?
  city         String?
  state        String?
  zipCode      String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tickets      Ticket[]
}

model TicketMessage {
  id          String   @id @default(uuid())
  content     String
  type        MessageType @default(TEXT)
  isInternal  Boolean  @default(false)
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  attachments Attachment[]
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("#3b82f6")
  tickets   Ticket[]
  createdAt DateTime @default(now())
}

model Attachment {
  id          String   @id @default(uuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  url         String
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id])
  messageId   String?
  message     TicketMessage? @relation(fields: [messageId], references: [id])
  uploadedById String
  uploadedBy  User     @relation(fields: [uploadedById], references: [id])
  createdAt   DateTime @default(now())
}

model Activity {
  id          String   @id @default(uuid())
  action      String
  description String?
  entityType  String
  entityId    String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  metadata    Json?
  createdAt   DateTime @default(now())
}

model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  revokedAt   DateTime?
}

enum Role {
  ADMIN
  MANAGER
  ATTENDANT
  VIEWER
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
  WAITING_CUSTOMER
  WAITING_THIRD_PARTY
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketSource {
  EMAIL
  PHONE
  CHAT
  PORTAL
  API
  OTHER
}

enum MessageType {
  TEXT
  SYSTEM
  EMAIL
  NOTE
}