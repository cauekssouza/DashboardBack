// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS (definidos UMA ÚNICA vez)
// ============================================
enum Role {
  ADMIN
  MANAGER
  ATTENDANT
  VIEWER
}

enum TicketStatus {
  ABERTO
  PENDENTE
  RESOLVIDO
  FECHADO
  CANCELADO
}

enum TicketPrioridade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum TicketTipo {
  SOLICITACAO
  CANCELAMENTO
  INTEGRACAO
  DUVIDA
  RECLAMACAO
  LEAD
}

// ============================================
// MODELO USER (CORRIGIDO)
// ============================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ATTENDANT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ REMOVA as linhas que estão causando erro
  // tickets      Ticket[]    @relation("CreatedTickets")
  // assignedTickets Ticket[] @relation("AssignedTickets")
  // messages     TicketMessage[]
  // refreshTokens RefreshToken[]
  // atividades   Atividade[]        ← NÃO EXISTE
  // anexos       Attachment[]       ← NÃO EXISTE
  // clienteAtividades ClienteAtividade[] ← NÃO EXISTE

  @@map("users")
}

// ============================================
// MODELO CLIENTE
// ============================================
model Cliente {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  telefone     String?
  empresa      String?
  cpfCnpj      String?
  tipo         String   @default("PF")
  status       String   @default("ATIVO")
  dataCadastro DateTime @default(now())
  observacoes  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ RELACIONAMENTOS
  tickets Ticket[]

  @@map("clientes")
}

// ============================================
// MODELO TICKET
// ============================================
model Ticket {
  id         String   @id @default(uuid())
  numero     Int      @default(autoincrement())
  assunto    String
  descricao  String?
  tipo       String   @default("SOLICITACAO")
  prioridade Int      @default(2)
  status     String   @default("ABERTO")
  
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id])
  
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  resolvidoEm DateTime?
  prazoSLA   DateTime
  
  @@unique([numero])
  @@map("tickets")
}

